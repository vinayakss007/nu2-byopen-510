# NuCRM Environment Variables
# Copy this file to .env.local and fill in your values

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/nucrm
DATABASE_SSL=false
DATABASE_POOL_SIZE=5

# Authentication
JWT_SECRET=<generate-with: openssl rand -base64 64>
SETUP_KEY=<generate-with: openssl rand -hex 24>
CRON_SECRET=<generate-with: openssl rand -hex 48>

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
NODE_ENV=production

# Redis
REDIS_URL=redis://host:6379

# Email (Resend)
RESEND_API_KEY=re_xxxxxx

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# WhatsApp (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Voice (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Storage (S3/R2)
BACKUP_BUCKET=nucrm-backups
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_REGION=auto
# For Cloudflare R2:
S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# Backup settings
BACKUP_KEEP_DAYS=30

# ── Sentry (Error Tracking) ────────────────────────────
# Get your DSN from: https://sentry.io
SENTRY_DSN=https://75fe1c7657eb514f21c588c4e4928e5e@o4511370775887872.ingest.us.sentry.io/4511370776870912
NEXT_PUBLIC_SENTRY_DSN=https://75fe1c7657eb514f21c588c4e4928e5e@o4511370775887872.ingest.us.sentry.io/4511370776870912
SENTRY_ORG=nucrm
SENTRY_PROJECT=nucrm-app
SENTRY_AUTH_TOKEN=
SENTRY_ENABLE=true
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Grafana (Monitoring) ───────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ── Stripe (Billing) ───────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxx
STRIPE_PRICE_ID_MONTHLY=price_xxxxxx
STRIPE_PRICE_ID_YEARLY=price_xxxxxx
